header.header
  .container
    .inner-wrap

      // Menu Mobile
      .inner-menu-mobile
        i.fa-solid.fa-bars

      // Logo
      .inner-logo
        a(href="/")
          img(
            alt=settingWebsiteInfo.websiteName
            src=settingWebsiteInfo.logo
          )
          span= settingWebsiteInfo.websiteName

      // Menu
      nav.inner-menu
        .inner-overlay

        ul
          li
            a(class=(currentPath === '/' ? 'active' : undefined) href="/") Trang Chủ

          each item in categoryList
            - var isParentActive = navActiveSlug === item.slug
            if item.children && item.children.length
              each itemChild in item.children
                if navActiveSlug === itemChild.slug
                  - isParentActive = true
            li.menu-item
              a(class=(isParentActive ? 'active' : undefined) href=`/category/${item.slug}`) #{item.name}

              if (item.children && item.children.length > 0)
                i.fa-solid.fa-caret-down

                ul.sub-menu
                  each itemChild in item.children
                    li
                      a(
                        class=(navActiveSlug === itemChild.slug ? 'active' : undefined)
                        href=`/category/${itemChild.slug}`
                        ) #{itemChild.name}

          li
            a(href="/#news") Tin Tức

          li
            a(href="/#contact") Liên Hệ

      // Cart
      .inner-cart
        a(href="/cart")
          img(
            alt=""
            src="/assets/images/Icon.svg"
          )
          span(mini-cart) 
extends ../layouts/default.pug 

block main 
    h1.box-title Chỉnh sửa tài khoản quản trị

    //- Section 8
    .section-8 
        form(id="setting-account-admin-edit-form")
            .inner-group(style="display: none;")
                label(for="id" class="inner-label") Id
                input(type="text" id="id" name="id" value=accountDetail.id)
            .inner-group 
                label(for="fullName" class="inner-label") Họ tên
                input(type="text" id="fullName" name="fullName" value=accountDetail.fullName)
            .inner-group 
                label(for="email" class="inner-label") Email
                input(type="email" id="email" name="email" value=accountDetail.email)
            .inner-group 
                label(for="phone" class="inner-label") Số điện thoại
                input(type="number" id="phone" name="phone" value=accountDetail.phone)
            .inner-group 
                label(for="role" class="inner-label") Nhóm quyền
                select(id="role" name="role")
                    option(value="") -- Chọn nhóm quyền -- 
                    each item in roleList
                        option(
                            value=item.id
                            selected=(item.id == accountDetail.role ? true : false)
                            ) #{item.name}
            .inner-group 
                label(for="positionCompany" class="inner-label") Chức vụ
                input(type="text" id="positionCompany" name="positionCompany" value=accountDetail.positionCompany)
            .inner-group 
                label(for="status" class="inner-label") Trạng thái
                select(id="status" name="status")
                    option(
                        value="initial"
                        selected=(accountDetail.status == "initial" ? true : false)
                        ) Khởi tạo 
                    option(
                        value="active"
                        selected=(accountDetail.status == "active" ? true : false)
                        ) Hoạt động 
                    option(
                        value="inactive"
                        selected=(accountDetail.status == "inactive" ? true : false)
                        ) Tạm dừng
            .inner-group 
                label(for="password" class="inner-label") Mật khẩu
                input(type="text" id="password" name="password")
            .inner-group.inner-two-col 
                label(for="avatar" class="inner-label") Ảnh đại diện
                .inner-upload-image(image-default=accountDetail.avatar)
                    input(type="file" id="avatar" name="avatar" filepond-image)
            .inner-button.inner-two-col 
                button Cập nhật
        .inner-back
            a(href=`/${pathAdmin}/setting/account-admin/list`) Quay lại danh sách 
    //- End Section 8
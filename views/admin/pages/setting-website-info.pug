extends ../layouts/default.pug 
include ../mixins/options.pug

block main 
    h1.box-title Thông tin website

    //- Section 8
    .section-8 
        form(id="setting-website-info-form")
            .inner-group 
                label(for="websiteName" class="inner-label") Tên website
                input(type="text" id="websiteName" name="websiteName" value=record.websiteName)
            .inner-group 
                label(for="phone" class="inner-label") Số điện thoại
                input(type="text" id="phone" name="phone" value=record.phone)
            .inner-group 
                label(for="email" class="inner-label") Email
                input(type="email" id="email" name="email" value=record.email)
            .inner-group 
                label(for="address" class="inner-label") Địa chỉ
                input(type="text" id="address" name="address" value=record.address)
            //- .inner-group 
            //-     label(for="favicon" class="inner-label") Favicon
            //-     .inner-upload-image(image-default=record.favicon)
            //-         input(type="file" id="favicon" name="favicon" filepond-image)
            .inner-group 
                label(for="categoryIdSection4" class="inner-label") Danh mục cho Section 4
                select(id="categoryIdSection4" name="categoryIdSection4")
                    option(value="") -- Chọn danh mục --  
                    +options(categoryList, 0, record.categoryIdSection4)
            .inner-group 
                label(for="categoryIdSection6" class="inner-label") Danh mục cho Section 6
                select(id="categoryIdSection6" name="categoryIdSection6")
                    option(value="") -- Chọn danh mục --  
                    +options(categoryList, 0, record.categoryIdSection6)
            .inner-group 
                label(for="logo" class="inner-label") Logo
                .inner-upload-image(image-default=record.logo)
                    input(type="file" id="logo" name="logo" filepond-image)
            .inner-button.inner-two-col 
                button Cập nhật
        .inner-back
            a(href=`/${pathAdmin}/setting/list`) Quay lại danh sách 
    //- End Section 8
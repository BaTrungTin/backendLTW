extends ../layouts/default.pug 

block main 
    h1.box-title Chỉnh sửa nhóm quyền

    //- Section 8
    .section-8 
        form(id="setting-role-edit-form")
            .inner-group(style="display: none;")
                label(for="id" class="inner-label") Id
                input(type="text" id="id" name="id" value=roleDetail.id)
            .inner-group 
                label(for="name" class="inner-label") Tên nhóm quyền
                input(type="text" id="name" name="name" value=roleDetail.name)
            .inner-group 
                label(for="description" class="inner-label") Mô tả ngắn
                input(type="text" id="description" name="description" value=roleDetail.description)
            .inner-group 
                label(class="inner-label") Phân quyền
                .inner-checkbox-list 
                    each item in permissionList
                        .inner-checkbox-item 
                            input(
                                type="checkbox" 
                                id=`permissions-${item.value}`
                                name="permissions" 
                                value=item.value
                                checked=(roleDetail.permissions.includes(item.value))
                                )
                            label(
                                for=`permissions-${item.value}`
                                ) #{item.label}
            .inner-button.inner-two-col 
                button Cập nhật
        .inner-back
            a(href=`/${pathAdmin}/setting/role/list`) Quay lại danh sách 
    //- End Section 8
extends ../layouts/default.pug 
include ../mixins/options.pug

block main 
    h1.box-title Chỉnh sửa danh mục

    //- Section 8
    .section-8 
        form(id="category-edit-form")
            .inner-group(style="display: none;")
                label(for="id" class="inner-label") Id
                input(type="text" id="id" name="id" value=categoryDetail.id)
            .inner-group 
                label(for="name" class="inner-label") Tên danh mục
                input(type="text" id="name" name="name" value=categoryDetail.name)
            .inner-group 
                label(for="parent" class="inner-label") Danh mục cha
                select(id="parent" name="parent")
                    option(value="") -- Chọn danh mục --  
                    +options(categoryList, 0, categoryDetail.parent)
            .inner-group 
                label(for="position" class="inner-label") Vị trí
                input(type="number" id="position" name="position" value=categoryDetail.position)
            .inner-group 
                label(for="status" class="inner-label") Trạng thái
                select(id="status" name="status")
                    option(
                        value="active" 
                        selected=(categoryDetail.status == "active" ? true : false)
                        ) Hoạt động
                    option(
                        value="inactive" 
                        selected=(categoryDetail.status == "inactive" ? true : false)
                        ) Tạm dừng
            .inner-group.inner-two-col 
                label(for="avatar" class="inner-label") Ảnh đại diện
                .inner-upload-image(image-default=categoryDetail.avatar)
                    input(type="file" id="avatar" filepond-image  name="avatar")
            .inner-group.inner-two-col 
                label(for="description" class="inner-label") Mô tả
                textarea(id="description" textarea-mce name="description") #{categoryDetail.description}
            .inner-button.inner-two-col 
                button Cập nhật
        .inner-back
            a(href=`/${pathAdmin}/category/list`) Quay lại danh sách 
    //- End Section 8
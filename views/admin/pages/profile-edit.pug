extends ../layouts/default.pug 

block main 
    h1.box-title Thông tin cá nhân

    //- Section 8
    .section-8 
        form(id="profile-edit-form")
            .inner-group 
                label(for="fullName" class="inner-label") Họ tên
                input(type="text" id="fullName" name="fullName" value=account.fullName)
            .inner-group 
                label(for="email" class="inner-label") Email
                input(type="email" id="email" name="email" value=account.email)
            .inner-group 
                label(for="phone" class="inner-label") Số điện thoại
                input(type="number" id="phone" name="phone" value=account.phone)
            .inner-group 
                label(for="positionCompany" class="inner-label") Chức vụ
                input(type="text" id="positionCompany" readonly value=account.positionCompany)
            .inner-group 
                label(for="role" class="inner-label") Nhóm quyền
                input(type="text" id="role" readonly value=account.roleName)
            .inner-group.inner-two-col 
                label(for="avatar" class="inner-label") Ảnh đại diện
                .inner-upload-image(image-default=account.avatar)
                    input(type="file" id="avatar" name="avatar" filepond-image)
            .inner-button.inner-two-col 
                button Cập nhật
        .inner-back
            a(href=`/${pathAdmin}/profile/change-password`) Đổi mật khẩu
    //- End Section 8